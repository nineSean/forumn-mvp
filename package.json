{
  "name": "forum-mvp",
  "private": true,
  "packageManager": "pnpm@10.12.3",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@forum/api",
    "dev:frontend": "turbo run dev --filter=@forum/shell --filter=@forum/forum --filter=@forum/user --filter=@forum/admin",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:routes": "node scripts/route-regression.mjs",
    "test:routes:unit": "node --test scripts/route-regression.test.mjs",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "@module-federation/nextjs-mf"
    ]
  }
}
